rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Photos de profil et reçus : tout utilisateur authentifié peut lire/écrire.
    // Simplifié pour fiabilité — même logique que les règles Firestore.
    match /profiles/{fileName} {
      allow read, write: if request.auth != null;
    }

    match /receipts/{fileName} {
      allow read, write: if request.auth != null &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }
  }
}
