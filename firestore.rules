rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Chaque utilisateur ne peut lire/modifier que son propre profil
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Un couple ne peut être lu/modifié QUE par ses membres
    match /couples/{coupleId} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.memberUids;

      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.memberUids;

      allow update: if request.auth != null &&
        request.auth.uid in resource.data.memberUids;

      // Les transactions stockent leur propre copie de memberUids (dupliquée
      // depuis le couple parent au moment de la création) pour éviter toute
      // dépendance à get() dans les règles, plus fiable et plus rapide.
      match /transactions/{transactionId} {
        allow read: if request.auth != null &&
          request.auth.uid in resource.data.memberUids;

        allow create: if request.auth != null &&
          request.auth.uid in request.resource.data.memberUids;

        allow update, delete: if request.auth != null &&
          request.auth.uid in resource.data.memberUids;
      }
    }
  }
}
