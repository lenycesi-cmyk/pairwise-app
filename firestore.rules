rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Chaque utilisateur authentifié peut lire/modifier son propre profil
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Tout utilisateur authentifié peut lire/modifier les couples et leurs
    // transactions. Simplifié volontairement : à ce stade du projet (usage
    // personnel, pas de données sensibles de tiers), la sécurité fine n'est
    // pas prioritaire par rapport à la fiabilité. À renforcer plus tard si
    // l'app grandit au-delà d'un usage privé entre vous deux.
    match /couples/{coupleId} {
      allow read, write: if request.auth != null;

      match /transactions/{transactionId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
