rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Chaque utilisateur ne peut lire/modifier que son propre profil
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Un couple ne peut être lu/modifié QUE par ses membres
    // (memberUids est un tableau plat de strings, maintenu en parallèle de `members`)
    match /couples/{coupleId} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.memberUids;

      // Création : autorisée à tout utilisateur connecté, à condition qu'il
      // s'ajoute lui-même comme premier membre du couple qu'il crée.
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.memberUids;

      // Mise à jour : seuls les membres déjà présents dans le couple peuvent modifier
      // (ex: ajouter un nouveau membre, changer les réglages, ajouter des actifs...)
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.memberUids;

      // Les transactions ne sont accessibles qu'aux membres du couple parent
      match /transactions/{transactionId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.memberUids;
      }
    }
  }
}
